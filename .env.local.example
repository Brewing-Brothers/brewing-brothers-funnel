# ============================================================
# Brewing Brothers — Environment Variables Template
# COPY this file to .env.local and fill in real values
# NEVER commit .env.local to GitHub
# ============================================================

# ── LIVE NOW (Phase 2) ──────────────────────────────────────
APPS_SCRIPT_WEB_APP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
NEXT_PUBLIC_THEME=rustic
NEXT_PUBLIC_BASE_URL=https://brewing-brothers-funnel.vercel.app

# ── STRIPE — Phase 2 M3-M8 (blocked on client prices) ──────
NEXT_PUBLIC_STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
NEXT_PUBLIC_STRIPE_PRICE_SINGLE=price_SINGLE_ID
NEXT_PUBLIC_STRIPE_PRICE_SIXPACK=price_SIXPACK_ID
NEXT_PUBLIC_STRIPE_PRICE_TWELVE=price_TWELVE_ID

# ── DISPLAY PRICES — Phase 2 M3 (get from client) ──────────
NEXT_PUBLIC_PRICE_SINGLE=$---
NEXT_PUBLIC_PRICE_SIXPACK=$---
NEXT_PUBLIC_PRICE_TWELVE=$---

# ── EMAIL — Phase 3/4 ───────────────────────────────────────
# BREVO_API_KEY=your_brevo_key
# MAILERLITE_API_KEY=your_mailerlite_key

# ── HubSpot CRM — Phase 3 ───────────────────────────────────
# HUBSPOT_API_KEY=your_hubspot_key
